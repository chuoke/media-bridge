{
    "name": "chuoke/media-bridge",
    "description": "A unified bridge for multiple media sources: Unsplash, Pexels, Pixabay, Bing and more",
    "keywords": [
        "chuoke",
        "media",
        "image",
        "gallery",
        "unsplash",
        "pexels",
        "pixabay",
        "bing"
    ],
    "homepage": "https://github.com/chuoke/media-bridge",
    "license": "MIT",
    "authors": [
        {
            "name": "chuoke",
            "email": "chuokechungyoung@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "pestphp/pest": "^4.4.5"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel integration (ServiceProvider and Facade)"
    },
    "autoload": {
        "psr-4": {
            "Chuoke\\MediaBridge\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chuoke\\MediaBridge\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chuoke\\MediaBridge\\Laravel\\MediaServiceProvider"
            ],
            "aliases": {
                "Media": "Chuoke\\MediaBridge\\Laravel\\Media"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
